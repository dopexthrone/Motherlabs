{"prev_hash":"sha256:c072541d3431e62dc7f05afae0cf4aa6aa81abcc0d3eb10214963811270d9fc0","record":{"artifact_id":"sha256:e968fc547b61ffd280630d074c378e31c3c91ebf33a406555550777dba324ce4","artifact_kind":"evidence","content_hash":"sha256:e968fc547b61ffd280630d074c378e31c3c91ebf33a406555550777dba324ce4","evidence_kind":"llm_response","metadata":{"created_at_utc":"2025-12-14T18:16:24.176Z","description":"LLM response from ollama/llama3.1:8b-instruct-q4_K_M","related_artifacts":null,"tags":["ollama","llama3.1:8b-instruct-q4_K_M"]},"payload":"import { decomposeTask, printTaskTree } from './decompose'\nimport { Ledger } from './evidence'\nimport { LLMAdapter } from './llm'\nimport { Config } from './types'\n\nexport async function handleHelp(): Promise<void> {\n  console.log('Motherlabs Runtime v0.2.0')\n  console.log('')\n  console.log('Commands:')\n  console.log('  decompose <task>  - Break task into subtasks (uses LLM if ANTHROPIC_API_KEY set)')\n  console.log('  dogfood [once]    - Run self-improvement cycle')\n  console.log('    --anthropic     - Use Anthropic Claude (default: claude-sonnet-4-5)')\n  console.log('    --openai        - Use OpenAI GPT (default: gpt-4o)')\n  console.log('    --model <name>  - Specify model name')\n  console.log('  help              - Show this message')\n  console.log('')\n  console.log('Environment:')\n  console.log('  ANTHROPIC_API_KEY  - Required for Anthropic provider')\n  console.log('  OPENAI_API_KEY     - Required for OpenAI provider')\n  console.log('  KERNEL_PATH        - Path to kernel repo (default: /home/motherlabs/motherlabs-kernel)')\n  process.exit(0)\n}\n\nexport async function parseConfig(): Promise<Config> {\n  const kernelPath = process.env.KERNEL_PATH || '/home/motherlabs/motherlabs-kernel'\n  const anthropicApiKey = process.env.ANTHROPIC_API_KEY\n  return { kernelPath, anthropicApiKey, maxDepth: 3, maxSubtasks: 10 }\n}\n\nexport async function createLedger(config: Config): Promise<Ledger> {\n  return new Ledger()\n}\n\nexport async function createLlmAdapter(config: Config): Promise<LLMAdapter | undefined> {\n  if (config.anthropicApiKey) {\n    return new LLMAdapter(config.anthropicApiKey)\n  }\n  return undefined\n}\n\nexport async function handleDecompose(args: string[], config: Config, llm: LLMAdapter | undefined): Promise<void> {\n  const taskInput = args.slice(1).join(' ')\n  if (!taskInput) {\n    console.error('Error: No task provided')\n    process.exit(1)\n  }\n\n  console.log(llm ? 'Using LLM decomposition...' : 'Using heuristic decomposition (set ANTHROPIC_API_KEY for LLM)')\n}\n\nexport async function main(): Promise<void> {\n  const args = process.argv.slice(2)\n  const command = args[0]\n\n  if (!command || command === 'help') {\n    await handleHelp()\n  }\n\n  const config = await parseConfig()\n  const ledger = await createLedger(config)\n  const llm = await createLlmAdapter(config)\n\n  switch (command) {\n    case 'decompose':\n      await handleDecompose(args, config, llm)\n      break\n    // Add more cases for other commands\n    default:\n      console.error('Error: Unknown command')\n      process.exit(1)\n  }\n}","payload_encoding":"utf8"},"record_hash":"sha256:1636bc3019b22be78661e678385113ac86ed031ccdea610b580559a2de8dc33e","record_type":"EVIDENCE_ARTIFACT","seq":15,"timestamp":1765736184176}
