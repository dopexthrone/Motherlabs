{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "motherlabs://schemas/codeanalysis.schema.json",
  "title": "Code Analysis Result Schema",
  "type": "object",
  "required": ["filepath", "timestamp", "metrics", "issues"],
  "properties": {
    "filepath": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "number",
      "minimum": 0
    },
    "metrics": {
      "type": "object",
      "required": ["complexity", "linesOfCode", "functions", "testCoverage"],
      "properties": {
        "complexity": {
          "type": "number",
          "minimum": 0
        },
        "linesOfCode": {
          "type": "number",
          "minimum": 0
        },
        "functions": {
          "type": "number",
          "minimum": 0
        },
        "testCoverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "line", "message"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["NO_TESTS", "HIGH_COMPLEXITY", "DUPLICATE_CODE", "NO_ERROR_HANDLING", "MISSING_TYPES"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "line": {
            "type": "number",
            "minimum": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "fixable": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
