{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "motherlabs://schemas/gateresult.schema.json",
  "title": "Gate Result Schema",
  "type": "object",
  "required": ["gateName", "passed", "required"],
  "properties": {
    "gateName": {
      "type": "string",
      "enum": [
        "schema_validation",
        "syntax_validation",
        "variable_resolution",
        "test_execution",
        "urco_entropy",
        "governance_check"
      ]
    },
    "passed": {
      "type": "boolean"
    },
    "required": {
      "type": "boolean"
    },
    "error": {
      "type": "string"
    },
    "details": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
