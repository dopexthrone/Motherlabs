{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generatecoderesult.schema.json",
  "title": "GenerateCodeResult",
  "description": "Result of constrained code generation",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "Generated code that passed all gates"
    },
    "validation": {
      "$ref": "codevalidationresult.schema.json"
    },
    "attempts": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of attempts before success"
    },
    "evidenceId": {
      "type": "string",
      "description": "ID of evidence record"
    }
  },
  "required": ["code", "validation", "attempts", "evidenceId"],
  "additionalProperties": false
}
